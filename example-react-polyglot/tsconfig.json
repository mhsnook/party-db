{
  // the browser/client half (App, main, collections, auth). server.ts targets the
  // workers runtime — DOM and Workers types clash in one config — so it's
  // typechecked by tsconfig.worker.json instead. `pnpm typecheck` runs both.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["src/server.ts", "src/migrations"]
}
