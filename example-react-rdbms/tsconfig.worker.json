{
  // the worker half (server.ts). It targets the Cloudflare Workers runtime, so it
  // uses @cloudflare/workers-types (the `Cloudflare` namespace, DurableObject ctx)
  // and no DOM lib — the mirror of the repo's tsconfig.server.json.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/server.ts", "src/schema.ts", "src/env.d.ts"]
}
