{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": ["src/client", "src/protocol.ts", "src/schema.ts", "src/index.ts", "test"],
