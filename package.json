{
  "name": "party-db",
  "version": "0.0.0",
  "private": true,
  "description": "MOCK / PROPOSAL — multiplexed TanStack DB collection sync over a single transport (Durable Object WS, or PostgREST SSE). Not wired into scenetest-cloud; lives here for problem-space context, destined for its own monorepo.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./server": "./src/server/index.ts",
    "./protocol": "./src/protocol.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.8.59",
    "@cloudflare/workers-types": "^4",
    "typescript": "^5.7",
    "vitest": "^3",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "peerDependencies": {
    "@standard-schema/spec": "*",
    "@tanstack/db": "*",
    "partyserver": "*",
    "partysocket": "*"
  },
  "peerDependenciesMeta": {
    "partysocket": {
      "optional": true
    },
    "partyserver": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
