{
  "name": "party-db",
  "version": "0.0.1",
  "description": "Multiplexed TanStack DB collection sync over a PartyKit transport",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhsnook/party-db.git"
  },
  "homepage": "https://github.com/mhsnook/party-db#readme",
  "bugs": {
    "url": "https://github.com/mhsnook/party-db/issues"
  },
  "keywords": [
    "tanstack-db",
    "partykit",
    "partyserver",
    "durable-objects",
    "sync",
    "realtime",
    "cloudflare"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "default": "./dist/protocol.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.client.json && tsc -p tsconfig.build.server.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.server.json && tsc -p tsconfig.integration.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "bench": "node --experimental-transform-types --experimental-sqlite --no-warnings test/bench/index.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.20",
    "@cloudflare/workers-types": "^4",
    "typescript": "^5.7",
    "vitest": "^4.1.9",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "peerDependencies": {
    "@standard-schema/spec": "*",
    "@tanstack/db": "*",
    "partyserver": "*",
    "partysocket": "*"
  },
  "peerDependenciesMeta": {
    "partysocket": {
      "optional": true
    },
    "partyserver": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
