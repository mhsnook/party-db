{
  "name": "party-db",
  "version": "0.0.0",
  "private": true,
  "description": "MOCK / PROPOSAL — multiplexed TanStack DB collection sync over a single transport (Durable Object WS, or PostgREST SSE). Not wired into scenetest-cloud; lives here for problem-space context, destined for its own monorepo.",
